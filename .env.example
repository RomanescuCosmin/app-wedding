# Supabase — proiectul tău (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Parola pentru zona de administrare
ADMIN_PASSWORD=

# Personalizare nuntă (afișate public în interfață)
NEXT_PUBLIC_COUPLE_NAMES=Ana & Mihai
NEXT_PUBLIC_WEDDING_DATE=2026-06-12

# Opțional. Dacă e setat, fixează URL-ul folosit pentru codul QR din zona
# admin (are prioritate față de detectarea automată din browser). Util în
# producție ca să fixezi domeniul, ex. https://numele-tau.vercel.app
# (lasă gol pentru rulare locală).
NEXT_PUBLIC_SITE_URL=
